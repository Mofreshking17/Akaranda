# Safety net for the whole monorepo — subprojects also have their own .gitignore

# dependencies
**/node_modules/
**/.pnp
.pnp.*

# next.js build output
**/.next/
**/out/
**/build/

# env / secrets — NEVER commit these
**/.env
**/.env.local
**/.env*.local
!**/.env.local.example

# misc
.DS_Store
*.pem
*.tsbuildinfo
**/next-env.d.ts

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# editor
.vscode/
.idea/
