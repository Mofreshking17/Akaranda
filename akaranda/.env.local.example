# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=akaranda-media

# Server-only — used by public-site server actions for write-backs (orders, wardrobe, newsletter)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack — Settings > API Keys & Webhooks in the Paystack dashboard.
# Secret key is server-only: used to initialize/verify transactions and to
# verify webhook signatures. Never expose it to the client or prefix it
# with NEXT_PUBLIC_.
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
