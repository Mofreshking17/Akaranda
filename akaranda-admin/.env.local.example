# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket used by the Media Library
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=akaranda-media

# Site
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3000
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3001

# Direct Postgres password — used only by local migration/seed scripts (scripts/*.mjs)
SUPABASE_DB_PASSWORD=your-database-password

# Email notifications (order status changes) — fill in when ready
RESEND_API_KEY=
EMAIL_FROM=orders@akarandafashion.com

# Paystack — same project as the storefront's keys. Used server-only by the
# admin Payments module's "Verify Again" action. Never expose the secret key
# to the client.
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
